{
  "manifest_version": 3,
  "name": "Kvasir",
  "version": "0.6.0",
  "description": "Kvasir — interactive, in-browser code walkthroughs on GitHub, with select-code Q&A.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8799/*"
  ],
  "background": {
    "service_worker": "dist/huginn.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/pull/*",
        "https://github.com/*/*/blob/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "css": [
        "dist/midgard.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Kvasir",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/mermaid.mjs"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ]
}
