{
  "manifest_version": 3,
  "name": "Kvasir",
  "version": "0.1.0",
  "description": "Kvasir — Claude-authored interactive code walkthroughs on GitHub, with select-code Q&A via a local channel.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8799/*"],
  "background": { "service_worker": "dist/huginn.js" },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*", "https://github.com/*/*/blob/*"],
      "js": ["dist/content.js"],
      "css": ["dist/midgard.css"],
      "run_at": "document_idle"
    }
  ]
}
