{
  "manifest_version": 3,
  "name": "PR Walkthrough",
  "version": "0.1.0",
  "description": "Renders Claude-authored interactive walkthroughs on GitHub PRs, with code-selection Q&A via a local channel.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8799/*"],
  "background": { "service_worker": "dist/huginn.js" },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["dist/content.js"],
      "css": ["dist/midgard.css"],
      "run_at": "document_idle"
    }
  ]
}
