{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": ["**/*.css"],
  "ignoreDependencies": ["tailwindcss"],
  "workspaces": {
    "packages/extension": {
      "entry": ["src/content/index.tsx", "src/huginn.ts", "src/mermaidEntry.ts"],
      "project": "src/**"
    },
    "packages/mimir": {
      "entry": ["src/channel.ts", "scripts/buildReview.ts", "src/**/*.buntest.ts"],
      "project": "src/**"
    },
    "packages/runes": { "project": "src/**" }
  }
}
