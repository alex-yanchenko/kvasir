{
  "name": "pr-walkthrough",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn a GitHub PR into an interactive, in-browser walkthrough with a select-code-and-ask modal, powered by a local Claude Code channel.",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "server": "pnpm --filter @prw/server start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.9"
  }
}
