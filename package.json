{
  "name": "kvasir",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Turn a GitHub PR into an interactive, in-browser walkthrough with a select-code-and-ask modal, powered by a local Claude Code channel.",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "mimir": "pnpm --filter @kvasir/mimir start",
    "build": "pnpm --filter @kvasir/extension build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "knip": "knip",
    "type-coverage": "type-coverage --strict --at-least 98",
    "size": "pnpm build && size-limit",
    "spell": "cspell \"packages/*/src/**/*.{ts,tsx}\" \"*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:coverage": "NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
    "e2e": "pnpm build && playwright test",
    "mutation": "NODE_OPTIONS=--no-experimental-webstorage stryker run"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "cspell": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "size-limit": "^12.1.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
